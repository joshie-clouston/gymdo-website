---
const TRIAL_URL = 'https://gymdo-staff-app-main-yzbyzu.laravel.cloud/register';
const navLinks = [
  { label: 'Features', href: '/features' },
  { label: 'Pricing', href: '/pricing' },
  { label: 'About', href: '/about' },
];
---
<header class="fixed top-0 left-0 right-0 z-50 border-b border-white/5 bg-black/80 backdrop-blur-md">
  <div class="container flex items-center justify-between h-16">
    <!-- Logo -->
    <a href="/" class="flex items-center gap-2 font-bold text-xl tracking-tight">
      <span class="text-red-500">GymD</span><span class="text-white">o</span>
    </a>

    <!-- Desktop nav -->
    <nav class="hidden md:flex items-center gap-6">
      {navLinks.map(link => (
        <a
          href={link.href}
          class="text-sm text-zinc-400 hover:text-white transition-colors"
        >
          {link.label}
        </a>
      ))}
    </nav>

    <!-- CTA -->
    <div class="flex items-center gap-3">
      <a
        href="https://gymdo-staff-app-main-yzbyzu.laravel.cloud/login"
        class="hidden md:block text-sm text-zinc-400 hover:text-white transition-colors"
      >
        Sign in
      </a>
      <a href={TRIAL_URL} class="btn btn-primary btn-sm">
        Start free trial
      </a>
    </div>
  </div>
</header>
<div class="h-16" aria-hidden="true"></div>

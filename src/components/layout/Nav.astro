---
const TRIAL_URL = 'https://gymdo-staff-app-main-yzbyzu.laravel.cloud/register';
const navLinks = [
  { label: 'Features', href: '/gymdo-website/features' },
  { label: 'Pricing', href: '/gymdo-website/pricing' },
  { label: 'About', href: '/gymdo-website/about' },
];
---
<header class="fixed top-0 left-0 right-0 z-50 border-b border-slate-200/80 bg-white/90 backdrop-blur-md">
  <div class="container flex items-center justify-between h-16">
    <!-- Logo -->
    <a href="/gymdo-website/" class="flex items-center gap-2 font-bold text-xl tracking-tight">
      <span class="text-[#0891b2]">Gym</span><span class="text-[#0c2d4e]">Do</span>
    </a>

    <!-- Desktop nav -->
    <nav class="hidden md:flex items-center gap-6">
      {navLinks.map(link => (
        <a
          href={link.href}
          class="text-sm text-slate-500 hover:text-slate-900 transition-colors font-medium"
        >
          {link.label}
        </a>
      ))}
    </nav>

    <!-- CTA -->
    <div class="flex items-center gap-3">
      <a
        href="https://gymdo-staff-app-main-yzbyzu.laravel.cloud/login"
        class="hidden md:block text-sm text-slate-500 hover:text-slate-900 transition-colors font-medium"
      >
        Sign in
      </a>
      <a href={TRIAL_URL} class="btn btn-primary btn-sm">
        Start free trial
      </a>
    </div>
  </div>
</header>
<div class="h-16" aria-hidden="true"></div>

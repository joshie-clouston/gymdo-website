---
export const prerender = true;
import BaseLayout from '../../layouts/BaseLayout.astro';

const TRIAL_URL = 'https://gymdo-staff-app-main-yzbyzu.laravel.cloud/register';
const DEMO_EMAIL = 'josh@cmdsoftware.com.au';

const beltTimelines = [
  { belt: 'White', min: 'No minimum', next: 'Blue' },
  { belt: 'Blue', min: '2 years', next: 'Purple' },
  { belt: 'Purple', min: '1.5 years', next: 'Brown' },
  { belt: 'Brown', min: '1 year', next: 'Black' },
  { belt: 'Black', min: '31 years old minimum', next: 'Coral' },
];
---
<BaseLayout
  title="Belt Tracking - GymDo"
  description="IBJJF-aligned belt progression tracking for BJJ academies. Know exactly who is ready to grade. GymDo tracks time-in-belt automatically."
>
  <section class="section bg-[#0c2d4e] relative overflow-hidden">
    <div class="container relative" data-animate="fade-up">
      <div class="max-w-3xl">
        <span class="badge mb-4" style="background:rgba(34,211,238,0.12);color:#67e8f9;border-color:rgba(34,211,238,0.2);">Belt tracking</span>
        <h1 class="text-5xl md:text-6xl font-black text-white mb-6">Know exactly who's ready to grade</h1>
        <p class="text-slate-300 text-xl leading-relaxed mb-8">
          No more spreadsheet guessing. GymDo tracks every student's time at each belt against IBJJF minimums, automatically. Clear, objective data when promotion time comes.
        </p>
        <div class="flex flex-col sm:flex-row gap-4">
          <a href={TRIAL_URL} class="btn btn-primary btn-lg">Start free trial</a>
          <a href={`mailto:${DEMO_EMAIL}?subject=GymDo Belt Tracking Demo`} class="btn btn-outline-white btn-lg">Book a walkthrough</a>
        </div>
      </div>
    </div>
  </section>

  <section class="section bg-white">
    <div class="container">
      <div class="max-w-2xl mx-auto text-center mb-12" data-animate="fade-up">
        <h2 class="text-4xl font-black text-[#0c2d4e] mb-4">How it works</h2>
      </div>
      <div class="grid md:grid-cols-3 gap-6 max-w-4xl mx-auto" data-animate="stagger">
        <div class="card text-center">
          <div class="text-4xl font-black text-[#0891b2]/30 mb-4">01</div>
          <h3 class="text-[#0c2d4e] font-bold mb-2">Add members with their current belt</h3>
          <p class="text-slate-500 text-sm">Set belt rank, stripe count, and the date they received it. Import existing members in minutes.</p>
        </div>
        <div class="card text-center">
          <div class="text-4xl font-black text-[#0891b2]/30 mb-4">02</div>
          <h3 class="text-[#0c2d4e] font-bold mb-2">Attendance is tracked automatically</h3>
          <p class="text-slate-500 text-sm">Every class logged. GymDo calculates time-in-belt continuously against IBJJF minimums.</p>
        </div>
        <div class="card text-center">
          <div class="text-4xl font-black text-[#0891b2]/30 mb-4">03</div>
          <h3 class="text-[#0c2d4e] font-bold mb-2">Clear readiness dashboard</h3>
          <p class="text-slate-500 text-sm">See exactly who meets the minimum requirements for their next promotion, at a glance.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section bg-slate-50">
    <div class="container">
      <div class="max-w-2xl mx-auto text-center mb-12" data-animate="fade-up">
        <h2 class="text-4xl font-black text-[#0c2d4e] mb-4">IBJJF minimum time requirements</h2>
        <p class="text-slate-500">GymDo tracks these automatically for every member.</p>
      </div>
      <div class="max-w-2xl mx-auto space-y-3" data-animate="stagger">
        {beltTimelines.map(belt => (
          <div class="flex items-center justify-between p-4 rounded-lg border border-slate-200 bg-white">
            <div>
              <span class="text-[#0c2d4e] font-semibold">{belt.belt} belt</span>
              <span class="text-slate-400 text-sm ml-2">to {belt.next}</span>
            </div>
            <div class="text-slate-600 text-sm">{belt.min}</div>
          </div>
        ))}
      </div>
      <p class="text-center text-slate-400 text-xs mt-6">IBJJF requirements accurate as of 2026. Always verify with your governing body.</p>
    </div>
  </section>

  <section class="section bg-[#0c2d4e]">
    <div class="container text-center" data-animate="fade-up">
      <h2 class="text-4xl font-black text-white mb-4">Start tracking belt progression today</h2>
      <p class="text-slate-300 mb-8">Free 30-day trial. Full access. No credit card.</p>
      <a href={TRIAL_URL} class="btn btn-primary btn-lg">Start free trial</a>
    </div>
  </section>
</BaseLayout>

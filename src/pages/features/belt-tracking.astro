---
export const prerender = true;
import BaseLayout from '../../layouts/BaseLayout.astro';

const TRIAL_URL = 'https://gymdo-staff-app-main-yzbyzu.laravel.cloud/register';

const beltTimelines = [
  { belt: 'White', min: 'No minimum', next: 'Blue' },
  { belt: 'Blue', min: '2 years', next: 'Purple' },
  { belt: 'Purple', min: '1.5 years', next: 'Brown' },
  { belt: 'Brown', min: '1 year', next: 'Black' },
  { belt: 'Black', min: '31 years old minimum', next: 'Coral' },
];
---
<BaseLayout
  title="Belt Tracking - GymDo"
  description="GymDo tracks BJJ belt progression with IBJJF-aligned time-in-belt minimums. Know exactly who is ready to grade. Belt tracking built for BJJ academies."
>
  <!-- Hero -->
  <section class="section bg-black relative overflow-hidden">
    <div class="absolute inset-0 bg-[linear-gradient(to_right,#27272a33_1px,transparent_1px),linear-gradient(to_bottom,#27272a33_1px,transparent_1px)] bg-[size:64px_64px]" aria-hidden="true"></div>
    <div class="container relative" data-animate="fade-up">
      <div class="max-w-3xl">
        <span class="badge badge-red mb-4">Belt tracking</span>
        <h1 class="text-5xl md:text-6xl font-black text-white mb-6">
          Know exactly who's ready to grade
        </h1>
        <p class="text-zinc-400 text-xl leading-relaxed mb-8">
          No more spreadsheet tracking. No more gut-feel promotions. GymDo tracks every student's training time against IBJJF minimums so you can make confident, defensible promotion decisions.
        </p>
        <a href={TRIAL_URL} class="btn btn-primary btn-lg">Start free trial</a>
      </div>
    </div>
  </section>

  <!-- How it works -->
  <section class="section bg-zinc-950">
    <div class="container">
      <div class="max-w-2xl mx-auto text-center mb-12" data-animate="fade-up">
        <h2 class="text-4xl font-black text-white mb-4">How belt tracking works</h2>
      </div>

      <div class="grid md:grid-cols-3 gap-6 max-w-4xl mx-auto" data-animate="stagger">
        <div class="card text-center">
          <div class="text-4xl font-black text-red-500 mb-4">01</div>
          <h3 class="text-white font-bold mb-2">Add members with their current belt</h3>
          <p class="text-zinc-400 text-sm">Set their current belt rank, stripe count, and the date they received it. Import existing members in minutes.</p>
        </div>
        <div class="card text-center">
          <div class="text-4xl font-black text-red-500 mb-4">02</div>
          <h3 class="text-white font-bold mb-2">Attendance is tracked automatically</h3>
          <p class="text-zinc-400 text-sm">Every class they attend is logged. GymDo calculates their time-in-belt continuously against IBJJF minimums.</p>
        </div>
        <div class="card text-center">
          <div class="text-4xl font-black text-red-500 mb-4">03</div>
          <h3 class="text-white font-bold mb-2">Get a clear readiness dashboard</h3>
          <p class="text-zinc-400 text-sm">The belt readiness widget shows you exactly who meets the minimum requirements for their next promotion.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- IBJJF timelines -->
  <section class="section bg-black">
    <div class="container">
      <div class="max-w-2xl mx-auto text-center mb-12" data-animate="fade-up">
        <h2 class="text-4xl font-black text-white mb-4">IBJJF minimum time requirements</h2>
        <p class="text-zinc-400">GymDo tracks these automatically for every member.</p>
      </div>

      <div class="max-w-2xl mx-auto space-y-3" data-animate="stagger">
        {beltTimelines.map(belt => (
          <div class="flex items-center justify-between p-4 rounded-lg border border-white/5 bg-white/[0.02]">
            <div>
              <span class="text-white font-semibold">{belt.belt} belt</span>
              <span class="text-zinc-500 text-sm ml-2">to {belt.next}</span>
            </div>
            <div class="text-zinc-300 text-sm">{belt.min}</div>
          </div>
        ))}
      </div>

      <p class="text-center text-zinc-600 text-xs mt-6" data-animate="fade-in">
        IBJJF requirements accurate as of 2026. Requirements may vary. Always verify with your governing body.
      </p>
    </div>
  </section>

  <!-- CTA -->
  <section class="section bg-zinc-950">
    <div class="container text-center" data-animate="fade-up">
      <h2 class="text-4xl font-black text-white mb-4">Start tracking belt progression today</h2>
      <p class="text-zinc-400 mb-8">Free 30-day trial. Full access. No credit card.</p>
      <a href={TRIAL_URL} class="btn btn-primary btn-lg">Start free trial</a>
    </div>
  </section>
</BaseLayout>

---
export const prerender = true;
import BaseLayout from '../../layouts/BaseLayout.astro';

const TRIAL_URL = 'https://gymdo-staff-app-main-yzbyzu.laravel.cloud/register';
const DEMO_EMAIL = 'josh@cmdsoftware.com.au';
---
<BaseLayout
  title="Member Retention - GymDō"
  description="GymDō's member retention scoring flags at-risk BJJ academy members before they cancel. Attendance tracking and daily risk scores to keep your mats full."
>
  <section class="section bg-[#0c2d4e] relative overflow-hidden">
    <div class="container relative" data-animate="fade-up">
      <div class="max-w-3xl">
        <span class="badge mb-4" style="background:rgba(34,211,238,0.12);color:#67e8f9;border-color:rgba(34,211,238,0.2);">Member retention</span>
        <h1 class="text-5xl md:text-6xl font-black text-white mb-6">Know who needs a check-in before they drift</h1>
        <p class="text-slate-300 text-xl leading-relaxed mb-8">
          Most members don't cancel because of a bad experience. They drift quietly. GymDō spots the drift early and gives you the right moment to reach out.
        </p>
        <div class="flex flex-col sm:flex-row gap-4">
          <a href={TRIAL_URL} class="btn btn-primary btn-lg">Start free trial</a>
          <a href={`mailto:${DEMO_EMAIL}?subject=GymDō Retention Demo`} class="btn btn-outline-white btn-lg">Book a walkthrough</a>
        </div>
      </div>
    </div>
  </section>

  <section class="section bg-white">
    <div class="container">
      <div class="grid lg:grid-cols-2 gap-16 items-start">
        <div data-animate="fade-up">
          <h2 class="text-4xl font-black text-[#0c2d4e] mb-6">How retention scoring works</h2>
          <div class="space-y-6">
            {[
              { n:'1', title:'Attendance patterns are monitored', desc:'Every member\'s attendance frequency is tracked week-by-week. Declining frequency is the primary signal.' },
              { n:'2', title:'Risk score is calculated daily', desc:'Each member gets a score from 0 to 100. Higher means higher risk of cancellation. Updated every day.' },
              { n:'3', title:'High-risk members are flagged', desc:'The retention dashboard surfaces your highest-risk members so you know exactly who to check in on this week.' },
              { n:'4', title:'You reach out at the right time', desc:'A personal message from their coach, sent before they cancel, is worth far more than a win-back campaign after they\'ve left.' },
            ].map(s => (
              <div class="flex gap-4">
                <div class="w-8 h-8 rounded-lg bg-[#0891b2]/10 border border-[#0891b2]/20 flex items-center justify-center text-[#0891b2] flex-shrink-0 font-bold text-sm">{s.n}</div>
                <div>
                  <h3 class="text-[#0c2d4e] font-semibold mb-1">{s.title}</h3>
                  <p class="text-slate-400 text-sm">{s.desc}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
        <div data-animate="scale-in">
          <div class="card">
            <h4 class="text-[#0c2d4e] font-semibold text-sm mb-4">What drives the score</h4>
            <div class="space-y-2 mb-6">
              <div class="flex items-center justify-between text-sm"><span class="text-slate-500">Days since last class</span><span class="text-slate-600 font-medium">Primary signal</span></div>
              <div class="flex items-center justify-between text-sm"><span class="text-slate-500">Attendance trend (12 weeks)</span><span class="text-slate-600 font-medium">Strong signal</span></div>
              <div class="flex items-center justify-between text-sm"><span class="text-slate-500">Membership age</span><span class="text-slate-600 font-medium">Context</span></div>
            </div>
            <div class="space-y-2 border-t border-slate-100 pt-4">
              <div class="flex items-center gap-3"><div class="w-3 h-3 rounded-full bg-emerald-500"></div><span class="text-sm text-slate-600">0-30: Thriving</span></div>
              <div class="flex items-center gap-3"><div class="w-3 h-3 rounded-full bg-amber-400"></div><span class="text-sm text-slate-600">31-60: Watch closely</span></div>
              <div class="flex items-center gap-3"><div class="w-3 h-3 rounded-full bg-orange-500"></div><span class="text-sm text-slate-600">61-80: Reach out soon</span></div>
              <div class="flex items-center gap-3"><div class="w-3 h-3 rounded-full bg-rose-500"></div><span class="text-sm text-slate-600">81-100: At risk of cancellation</span></div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section bg-slate-50">
    <div class="container">
      <div class="max-w-2xl mx-auto text-center mb-12" data-animate="fade-up">
        <h2 class="text-4xl font-black text-[#0c2d4e] mb-4">The numbers add up quickly</h2>
        <p class="text-slate-500 text-lg">Retaining one member pays for a full year of GymDō.</p>
      </div>
      <div class="grid md:grid-cols-3 gap-6 max-w-3xl mx-auto" data-animate="stagger">
        <div class="card text-center">
          <div class="text-4xl font-black text-[#0891b2] mb-2">$140</div>
          <p class="text-[#0c2d4e] text-sm font-semibold">Average membership/mo</p>
        </div>
        <div class="card text-center">
          <div class="text-4xl font-black text-[#0891b2] mb-2">15 mo</div>
          <p class="text-[#0c2d4e] text-sm font-semibold">Average member tenure</p>
        </div>
        <div class="card text-center">
          <div class="text-4xl font-black text-[#0891b2] mb-2">$2,100</div>
          <p class="text-[#0c2d4e] text-sm font-semibold">Lifetime value per member</p>
        </div>
      </div>
      <p class="text-center text-slate-400 text-sm mt-8">Retaining one extra member per month more than pays for GymDō at any plan tier.</p>
    </div>
  </section>

  <section class="section bg-[#0c2d4e]">
    <div class="container text-center" data-animate="fade-up">
      <h2 class="text-4xl font-black text-white mb-4">Keep your mats full this month</h2>
      <p class="text-slate-300 mb-8">Free 30-day trial. Retention scoring included in every plan.</p>
      <a href={TRIAL_URL} class="btn btn-primary btn-lg">Start free trial</a>
    </div>
  </section>
</BaseLayout>

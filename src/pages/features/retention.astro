---
export const prerender = true;
import BaseLayout from '../../layouts/BaseLayout.astro';

const TRIAL_URL = 'https://gymdo-staff-app-main-yzbyzu.laravel.cloud/register';
---
<BaseLayout
  title="Member Retention - GymDo"
  description="GymDo's member retention scoring flags at-risk BJJ academy members before they cancel. Attendance heatmaps and risk scores to reduce gym member churn."
>
  <!-- Hero -->
  <section class="section bg-black relative overflow-hidden">
    <div class="absolute inset-0 bg-[linear-gradient(to_right,#27272a33_1px,transparent_1px),linear-gradient(to_bottom,#27272a33_1px,transparent_1px)] bg-[size:64px_64px]" aria-hidden="true"></div>
    <div class="container relative" data-animate="fade-up">
      <div class="max-w-3xl">
        <span class="badge badge-red mb-4">Member retention</span>
        <h1 class="text-5xl md:text-6xl font-black text-white mb-6">
          Stop losing members to silence
        </h1>
        <p class="text-zinc-400 text-xl leading-relaxed mb-8">
          Most members don't cancel because of a bad experience. They drift away. GymDo's retention scoring system spots the drift before it becomes a cancellation and gives you a reason to reach out.
        </p>
        <a href={TRIAL_URL} class="btn btn-primary btn-lg">Start free trial</a>
      </div>
    </div>
  </section>

  <!-- How scoring works -->
  <section class="section bg-zinc-950">
    <div class="container">
      <div class="grid lg:grid-cols-2 gap-16 items-start">
        <div data-animate="fade-up">
          <h2 class="text-4xl font-black text-white mb-6">How retention scoring works</h2>
          <div class="space-y-6">
            <div class="flex gap-4">
              <div class="w-8 h-8 rounded-lg bg-red-500/10 border border-red-500/20 flex items-center justify-center text-red-400 flex-shrink-0 font-bold text-sm">1</div>
              <div>
                <h3 class="text-white font-semibold mb-1">Attendance patterns are monitored</h3>
                <p class="text-zinc-400 text-sm">Every member's attendance frequency is tracked week-by-week. Declining attendance is the primary signal.</p>
              </div>
            </div>
            <div class="flex gap-4">
              <div class="w-8 h-8 rounded-lg bg-red-500/10 border border-red-500/20 flex items-center justify-center text-red-400 flex-shrink-0 font-bold text-sm">2</div>
              <div>
                <h3 class="text-white font-semibold mb-1">Risk score is calculated</h3>
                <p class="text-zinc-400 text-sm">Each member gets a risk score from 0 to 100. Higher scores mean higher risk. Scores update daily based on recent activity.</p>
              </div>
            </div>
            <div class="flex gap-4">
              <div class="w-8 h-8 rounded-lg bg-red-500/10 border border-red-500/20 flex items-center justify-center text-red-400 flex-shrink-0 font-bold text-sm">3</div>
              <div>
                <h3 class="text-white font-semibold mb-1">High-risk members are flagged</h3>
                <p class="text-zinc-400 text-sm">The retention dashboard surfaces your highest-risk members so you know exactly who to reach out to this week.</p>
              </div>
            </div>
            <div class="flex gap-4">
              <div class="w-8 h-8 rounded-lg bg-red-500/10 border border-red-500/20 flex items-center justify-center text-red-400 flex-shrink-0 font-bold text-sm">4</div>
              <div>
                <h3 class="text-white font-semibold mb-1">You reach out at the right time</h3>
                <p class="text-zinc-400 text-sm">A personal message from their coach, sent before they cancel, converts far better than a win-back campaign after they've already left.</p>
              </div>
            </div>
          </div>
        </div>

        <div data-animate="scale-in">
          <div class="rounded-2xl border border-white/5 bg-zinc-900 p-6">
            <h4 class="text-white font-semibold text-sm mb-4">Risk score breakdown</h4>
            <div class="space-y-3 mb-6">
              <div class="flex items-center justify-between text-sm">
                <span class="text-zinc-400">Days since last class</span>
                <span class="text-zinc-300">Primary signal</span>
              </div>
              <div class="flex items-center justify-between text-sm">
                <span class="text-zinc-400">Attendance trend (12 weeks)</span>
                <span class="text-zinc-300">Strong signal</span>
              </div>
              <div class="flex items-center justify-between text-sm">
                <span class="text-zinc-400">Membership age</span>
                <span class="text-zinc-300">Context signal</span>
              </div>
            </div>
            <div class="space-y-2">
              <div class="flex items-center gap-3">
                <div class="w-3 h-3 rounded-full bg-green-500"></div>
                <span class="text-sm text-zinc-300">0-30: Healthy</span>
              </div>
              <div class="flex items-center gap-3">
                <div class="w-3 h-3 rounded-full bg-yellow-500"></div>
                <span class="text-sm text-zinc-300">31-60: Watch closely</span>
              </div>
              <div class="flex items-center gap-3">
                <div class="w-3 h-3 rounded-full bg-orange-500"></div>
                <span class="text-sm text-zinc-300">61-80: Reach out soon</span>
              </div>
              <div class="flex items-center gap-3">
                <div class="w-3 h-3 rounded-full bg-red-500"></div>
                <span class="text-sm text-zinc-300">81-100: At risk of cancellation</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- The math -->
  <section class="section bg-black">
    <div class="container">
      <div class="max-w-2xl mx-auto text-center mb-12" data-animate="fade-up">
        <h2 class="text-4xl font-black text-white mb-4">The maths is compelling</h2>
        <p class="text-zinc-400 text-lg">Retaining one member pays for a full year of GymDo.</p>
      </div>

      <div class="grid md:grid-cols-3 gap-6 max-w-3xl mx-auto" data-animate="stagger">
        <div class="card text-center">
          <div class="text-4xl font-black text-red-500 mb-2">$140</div>
          <p class="text-zinc-300 text-sm font-semibold">Average membership/mo</p>
        </div>
        <div class="card text-center">
          <div class="text-4xl font-black text-red-500 mb-2">15 mo</div>
          <p class="text-zinc-300 text-sm font-semibold">Average member tenure</p>
        </div>
        <div class="card text-center">
          <div class="text-4xl font-black text-red-500 mb-2">$2,100</div>
          <p class="text-zinc-300 text-sm font-semibold">Lifetime value per member</p>
        </div>
      </div>

      <p class="text-center text-zinc-500 text-sm mt-8" data-animate="fade-up">
        Retaining just one extra member per month more than pays for your GymDo subscription at any plan tier.
      </p>
    </div>
  </section>

  <!-- CTA -->
  <section class="section bg-zinc-950">
    <div class="container text-center" data-animate="fade-up">
      <h2 class="text-4xl font-black text-white mb-4">Start retaining more members this month</h2>
      <p class="text-zinc-400 mb-8">Free 30-day trial. Retention scoring included in every plan.</p>
      <a href={TRIAL_URL} class="btn btn-primary btn-lg">Start free trial</a>
    </div>
  </section>
</BaseLayout>

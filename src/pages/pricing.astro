---
export const prerender = true;
import BaseLayout from '../layouts/BaseLayout.astro';

const TRIAL_URL = 'https://gymdo-staff-app-main-yzbyzu.laravel.cloud/register';
const DEMO_EMAIL = 'josh@cmdsoftware.com.au';

const plans = [
  { range: 'Up to 50 members', price: 79, popular: false },
  { range: '51-150 members', price: 129, popular: true },
  { range: '151-300 members', price: 179, popular: false },
  { range: '300+ members', price: 229, popular: false },
];

const allFeatures = [
  'Unlimited class sessions',
  'Belt progression tracking',
  'Member retention scoring',
  'Member mobile app (iOS and Android)',
  'Stripe-powered billing and payments',
  'Attendance tracking and check-ins',
  'Waiver management',
  'Analytics dashboard',
  'Drop-in booking',
  'Email and SMS notifications',
  'Priority support',
  'Data export anytime',
];

const faqs = [
  {
    q: 'Is there a free trial?',
    a: '30 days free, no credit card required. Full access to every feature from day one. Your billing only starts after the trial ends.',
  },
  {
    q: 'Do you help with migration from my current software?',
    a: "Yes — and it's free. Send us your member list, your export from Mindbody, Glofox, or wherever you're coming from, and we import everything. Members, belt records, billing setup. You don't re-enter a single name. A personal onboarding call with Josh gets your class timetable and membership plans configured before you go live.",
  },
  {
    q: 'What happens if my gym grows past my plan limit?',
    a: "We notify you before you hit your limit and move you to the next tier automatically. No surprise charges, no service interruption. You'll always know exactly what you're paying.",
  },
  {
    q: 'Are there any percentage or transaction fees on top?',
    a: 'No platform cut. Standard Stripe payment processing fees apply (around 2.7%) — the same as any platform that accepts card payments. GymDō earns from your subscription only, not a percentage of your revenue. Pricing is in AUD. GST-compliant invoicing included.',
  },
  {
    q: 'Can I cancel anytime?',
    a: 'Yes. Month-to-month, no lock-in contracts. Cancel from within the platform with one click. We don\'t make it difficult because we don\'t want you to stay unless GymDō is genuinely the right fit.',
  },
  {
    q: 'What is the money back guarantee?',
    a: "If you're not satisfied in the first 30 days after your trial ends, email us and we'll refund your first payment. No questions, no forms to fill, no 30-day notice period.",
  },
  {
    q: 'Do all plans include all features?',
    a: 'Yes. No feature tiers, no add-ons, no upsells. Belt tracking, retention scoring, member app, analytics — all included at every plan level. You only pay more as your academy grows.',
  },
  {
    q: 'I\'m locked into a contract with my current provider. Can I still switch?',
    a: "If you're mid-contract, reach out anyway. We're happy to talk about timing, start the trial to get familiar with GymDō, and do the migration the moment you're ready to go live. We'll be here.",
  },
  {
    q: 'How long does setup actually take?',
    a: 'Most academies are live within 24 hours. The onboarding call takes under an hour. Your members can book classes the same day you go live.',
  },
  {
    q: 'I\'m not very technical. Will I be able to run this?',
    a: 'Yes. GymDō is built for coaches and gym owners, not IT departments. If something trips you up, you\'re emailing Josh directly — not submitting a support ticket.',
  },
  {
    q: 'What if GymDō is missing a feature I rely on?',
    a: 'Tell us on the onboarding call. Every feature in GymDō was built because a real gym owner needed it. If it fits our focus on BJJ academies, we\'ll build it. Feature requests from pilot gyms go directly into the roadmap.',
  },
  {
    q: 'Can I get a demo before signing up?',
    a: 'Absolutely. Email josh@cmdsoftware.com.au and we\'ll walk you through the platform live — screen share, your questions, no sales pitch. Just the product.',
  },
];
---
<BaseLayout
  title="Pricing - GymDō"
  description="GymDō gym management pricing. Flat monthly fee from $79/mo for BJJ academies. No platform percentage, no lock-in, 30-day free trial."
>
  <section class="section bg-[#0c2d4e] relative overflow-hidden">
    <div class="container relative text-center" data-animate="fade-up">
      <span class="badge mb-4" style="background:rgba(34,211,238,0.12);color:#67e8f9;border-color:rgba(34,211,238,0.2);">Pricing</span>
      <h1 class="text-5xl md:text-6xl font-black text-white mb-6">Flat pricing.<br />No surprises.</h1>
      <p class="text-slate-300 text-xl max-w-xl mx-auto">
        Pay based on how many members you have. No platform percentage, no upsells, no lock-in.
      </p>
    </div>
  </section>

  <section class="section bg-white">
    <div class="container">
      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6 max-w-5xl mx-auto" data-animate="stagger">
        {plans.map(plan => (
          <div class={`card flex flex-col relative ${plan.popular ? 'border-[#0891b2]' : ''}`}>
            {plan.popular && (
              <div class="absolute -top-3 left-1/2 -translate-x-1/2">
                <span class="badge badge-teal text-[10px]">Most popular</span>
              </div>
            )}
            <div class="mb-6">
              <div class="text-4xl font-black text-[#0c2d4e] mb-1">
                ${plan.price}<span class="text-base font-normal text-slate-400">/mo</span>
              </div>
              <div class="text-sm text-slate-400">{plan.range}</div>
            </div>
            <a href={TRIAL_URL} class={`btn btn-md w-full mt-auto ${plan.popular ? 'btn-primary' : 'btn-secondary'}`}>
              Start free trial
            </a>
          </div>
        ))}
      </div>
      <p class="text-center text-slate-400 text-sm mt-8">30-day free trial. No credit card required.</p>
    </div>
  </section>

  <section class="section bg-slate-50">
    <div class="container">
      <div class="max-w-2xl mx-auto text-center mb-12" data-animate="fade-up">
        <h2 class="text-4xl font-black text-[#0c2d4e] mb-4">Everything included in every plan</h2>
        <p class="text-slate-500">No feature tiers. No upsells.</p>
      </div>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-4 max-w-4xl mx-auto" data-animate="stagger">
        {allFeatures.map(feature => (
          <div class="flex items-center gap-3 p-4 rounded-lg border border-slate-200 bg-white">
            <span class="text-[#0891b2] font-bold flex-shrink-0">+</span>
            <span class="text-slate-600 text-sm">{feature}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section bg-white">
    <div class="container">
      <div class="max-w-2xl mx-auto text-center mb-12" data-animate="fade-up">
        <h2 class="text-4xl font-black text-[#0c2d4e] mb-4">Frequently asked questions</h2>
      </div>
      <div class="max-w-3xl mx-auto space-y-4" data-animate="stagger">
        {faqs.map(faq => (
          <div class="card">
            <h3 class="text-[#0c2d4e] font-bold mb-2">{faq.q}</h3>
            <p class="text-slate-500 text-sm leading-relaxed">{faq.a}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section bg-[#0c2d4e]">
    <div class="container text-center" data-animate="fade-up">
      <h2 class="text-4xl font-black text-white mb-4">Start your free trial today</h2>
      <p class="text-slate-300 mb-8">Or book a live walkthrough first.</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href={TRIAL_URL} class="btn btn-primary btn-lg">Start free trial</a>
        <a href={`mailto:${DEMO_EMAIL}?subject=GymDō Demo Request`} class="btn btn-outline-white btn-lg">Book a walkthrough</a>
      </div>
    </div>
  </section>
</BaseLayout>

---
export const prerender = true;
import BaseLayout from '../layouts/BaseLayout.astro';
import OrgSchema from '../components/schema/OrgSchema.astro';

const TRIAL_URL = 'https://gymdo-staff-app-main-yzbyzu.laravel.cloud/register';
const DEMO_EMAIL = 'josh@cmdsoftware.com.au';

const pains = [
  {
    icon: '📉',
    headline: 'You find out a member left when the payment stops',
    body: 'Not when they stopped training. Not when they stopped enjoying it. When the direct debit fails. By then they\'re already gone.',
  },
  {
    icon: '🥋',
    headline: 'Belt promotion time means guessing — or a spreadsheet',
    body: 'A student asks if they\'re ready. You try to remember how long they\'ve been training, when they got their last stripe. It\'s not a great moment.',
  },
  {
    icon: '🔧',
    headline: 'Your software has a spin class category',
    body: 'And fields for PT sessions, yoga memberships, and tanning credits. None of that exists on your mats. But you navigate around it every day.',
  },
  {
    icon: '💸',
    headline: 'You\'re paying $300/month for something that\'s never heard of a guard pass',
    body: 'Mindbody and Glofox were built for mainstream fitness. BJJ gyms are an afterthought. You\'re paying premium prices for a platform that doesn\'t understand your sport.',
  },
];

const features = [
  {
    title: 'Belt progression tracking',
    description: 'IBJJF-aligned time tracking from white to black. Know exactly who is ready to grade — with data to back it up.',
  },
  {
    title: 'Member retention scoring',
    description: 'Daily risk scores flag who is going quiet. Catch it two weeks before they cancel, not two weeks after.',
  },
  {
    title: 'Class scheduling and booking',
    description: 'Visual timetable, member booking app, automatic attendance marking. Your admin time back.',
  },
  {
    title: 'Membership and billing',
    description: 'Stripe-powered recurring billing. Pauses, cancellations, and failed payment retries handled without you lifting a finger.',
  },
  {
    title: 'Member app (iOS and Android)',
    description: 'Your members book classes, see their belt progress, and manage their own membership — without texting you.',
  },
  {
    title: 'Analytics dashboard',
    description: 'MRR, attendance trends, belt distribution, retention rate. The numbers you actually need, in one place.',
  },
];

const steps = [
  {
    num: '01',
    title: 'Import your members — done in under an hour',
    description: 'Add your gym, import your member list from a spreadsheet, set your class timetable. Most academies are live the same day they sign up.',
  },
  {
    num: '02',
    title: 'Your members get the app automatically',
    description: 'They receive a welcome email, download the app, and can book their first class and see their belt progress immediately. No manual setup on your end.',
  },
  {
    num: '03',
    title: 'Get back on the mat',
    description: 'Attendance tracks itself. Billing runs every month. You\'re notified when someone is drifting. Everything else just works.',
  },
];
---
<BaseLayout
  title="GymDō - Jiu Jitsu (BJJ) Gym Management Software"
  description="GymDō is BJJ gym management software purpose-built from the mat up. Belt tracking, member retention, billing and scheduling for Jiu Jitsu academies. 30-day free trial."
>
  <OrgSchema slot="structured-data" />

  <!-- Hero -->
  <section class="bg-[#0c2d4e] relative overflow-hidden pt-16 pb-24 md:pt-24 md:pb-32">
    <div class="absolute inset-0 opacity-[0.04]" style="background-image: radial-gradient(ellipse at 50% 0%, #22d3ee 0%, transparent 70%);" aria-hidden="true"></div>
    <div class="absolute bottom-0 left-0 right-0 h-1 bg-gradient-to-r from-transparent via-[#0891b2] to-transparent opacity-30" aria-hidden="true"></div>

    <div class="container relative">
      <div class="max-w-4xl mx-auto text-center">
        <h1 class="text-4xl md:text-6xl font-black text-white mb-6 leading-tight" data-animate="fade-up">
          Jiu Jitsu (BJJ) gym management software,<br />
          <span class="text-[#38bdf8]">purpose-built from the mat up.</span>
        </h1>

        <p class="text-xl text-slate-300 mb-10 max-w-2xl mx-auto leading-relaxed" data-animate="fade-up">
          Belt tracking that follows IBJJF standards. Member retention scoring that catches who's drifting before they cancel. Billing that runs itself. Built for BJJ academies — not adapted from a yoga studio template.
        </p>

        <div class="flex flex-col sm:flex-row gap-4 justify-center" data-animate="fade-up">
          <a href={TRIAL_URL} class="btn btn-primary btn-lg">
            Start free trial — 30 days
          </a>
          <a href={`mailto:${DEMO_EMAIL}?subject=GymDō Demo Request`} class="btn btn-outline-white btn-lg">
            Book a walkthrough
          </a>
        </div>

        <p class="mt-4 text-xs text-slate-500">No credit card required. Cancel anytime. 30-day money back guarantee after trial ends.</p>
      </div>

      <!-- Stats bar -->
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mt-20 max-w-3xl mx-auto" data-animate="stagger">
        <div class="text-center p-6 rounded-xl border border-white/8 bg-white/[0.04]">
          <div class="text-3xl font-black text-white mb-1">$79</div>
          <div class="text-xs text-slate-400 uppercase tracking-wider">Starts at /mo</div>
        </div>
        <div class="text-center p-6 rounded-xl border border-white/8 bg-white/[0.04]">
          <div class="text-3xl font-black text-white mb-1">30</div>
          <div class="text-xs text-slate-400 uppercase tracking-wider">Day free trial</div>
        </div>
        <div class="text-center p-6 rounded-xl border border-white/8 bg-white/[0.04]">
          <div class="text-3xl font-black text-white mb-1">&lt; 1hr</div>
          <div class="text-xs text-slate-400 uppercase tracking-wider">To go live</div>
        </div>
        <div class="text-center p-6 rounded-xl border border-white/8 bg-white/[0.04]">
          <div class="text-3xl font-black text-white mb-1">BJJ</div>
          <div class="text-xs text-slate-400 uppercase tracking-wider">Only. Always.</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Pain agitation -->
  <section class="section bg-white">
    <div class="container">
      <div class="max-w-2xl mx-auto text-center mb-16" data-animate="fade-up">
        <span class="badge badge-navy mb-4">Sound familiar?</span>
        <h2 class="text-4xl md:text-5xl font-black text-[#0c2d4e] mb-4">
          This is what running a BJJ gym on generic software looks like.
        </h2>
        <p class="text-slate-500 text-lg">If you recognise any of these, you already know why GymDō exists.</p>
      </div>

      <div class="grid md:grid-cols-2 gap-6 max-w-4xl mx-auto" data-animate="stagger">
        {pains.map(pain => (
          <div class="card border-slate-200 bg-slate-50">
            <div class="text-3xl mb-4">{pain.icon}</div>
            <h3 class="text-[#0c2d4e] font-bold text-lg mb-2">{pain.headline}</h3>
            <p class="text-slate-500 text-sm leading-relaxed">{pain.body}</p>
          </div>
        ))}
      </div>

      <div class="max-w-2xl mx-auto text-center mt-16" data-animate="fade-up">
        <p class="text-2xl font-bold text-[#0c2d4e] mb-3">None of this is your fault. It's your software.</p>
        <p class="text-slate-500 text-lg">Mindbody, Glofox, and Gymdesk weren't built for BJJ. They were bolted on. GymDō was designed around how your academy actually works — from the first stripe to the belt promotion, from the first class booking to the renewal reminder.</p>
      </div>
    </div>
  </section>

  <!-- Solution reveal -->
  <section class="section bg-[#0c2d4e] relative overflow-hidden">
    <div class="absolute inset-0 opacity-[0.04]" style="background-image: radial-gradient(ellipse at 50% 0%, #22d3ee 0%, transparent 70%);" aria-hidden="true"></div>
    <div class="container relative">
      <div class="max-w-3xl mx-auto text-center" data-animate="fade-up">
        <span class="badge mb-6" style="background:rgba(34,211,238,0.12);color:#67e8f9;border-color:rgba(34,211,238,0.2);">The fix</span>
        <h2 class="text-4xl md:text-5xl font-black text-white mb-6">
          One platform. Everything your academy needs. Nothing it doesn't.
        </h2>
        <p class="text-slate-300 text-xl leading-relaxed mb-10">
          GymDō replaces the spreadsheets, the payment chasing, the guesswork at grading time, and the subscriptions to platforms that don't understand BJJ. It runs quietly in the background while you run your academy.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href={TRIAL_URL} class="btn btn-primary btn-lg">Start free trial</a>
          <a href={`mailto:${DEMO_EMAIL}?subject=GymDō Demo Request`} class="btn btn-outline-white btn-lg">Book a walkthrough</a>
        </div>
      </div>
    </div>
  </section>

  <!-- How it works -->
  <section class="section bg-white">
    <div class="container">
      <div class="max-w-2xl mx-auto text-center mb-16" data-animate="fade-up">
        <span class="badge badge-teal mb-4">Getting started</span>
        <h2 class="text-4xl md:text-5xl font-black text-[#0c2d4e] mb-4">
          Live in a day, not a month
        </h2>
        <p class="text-slate-500 text-lg">No implementation fees. No consultant. No five-step onboarding. You'll have members booking classes today.</p>
      </div>

      <div class="grid md:grid-cols-3 gap-8 max-w-4xl mx-auto" data-animate="stagger">
        {steps.map(step => (
          <div class="text-center">
            <div class="text-5xl font-black text-[#0891b2]/20 mb-4">{step.num}</div>
            <h3 class="text-[#0c2d4e] font-bold text-lg mb-3">{step.title}</h3>
            <p class="text-slate-500 text-sm leading-relaxed">{step.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Product preview -->
  <section class="section bg-slate-50">
    <div class="container">
      <div class="max-w-2xl mx-auto text-center mb-12" data-animate="fade-up">
        <span class="badge badge-teal mb-4">See it in action</span>
        <h2 class="text-4xl md:text-5xl font-black text-[#0c2d4e] mb-4">
          Clean. Simple. Built for BJJ.
        </h2>
        <p class="text-slate-500 text-lg">No bloat. No generic menus. No fields for things that don't exist on your mats.</p>
      </div>

      <!-- Dashboard mockup -->
      <div class="max-w-4xl mx-auto" data-animate="scale-in">
        <div class="rounded-2xl border border-slate-200 bg-white shadow-xl overflow-hidden">
          <!-- Browser chrome -->
          <div class="bg-slate-100 border-b border-slate-200 px-4 py-3 flex items-center gap-2">
            <div class="flex gap-1.5">
              <div class="w-3 h-3 rounded-full bg-slate-300"></div>
              <div class="w-3 h-3 rounded-full bg-slate-300"></div>
              <div class="w-3 h-3 rounded-full bg-slate-300"></div>
            </div>
            <div class="flex-1 mx-4">
              <div class="bg-white rounded-md px-3 py-1 text-xs text-slate-400 max-w-xs mx-auto text-center border border-slate-200">
                app.gymdo.app/admin
              </div>
            </div>
          </div>

          <!-- Dashboard content -->
          <div class="p-4 sm:p-6 bg-slate-50">
            <!-- Top stats row -->
            <div class="grid grid-cols-2 sm:grid-cols-4 gap-2 sm:gap-3 mb-3 sm:mb-6">
              <div class="bg-white rounded-xl p-3 sm:p-4 border border-slate-200">
                <div class="text-xs text-slate-400 mb-1">Members</div>
                <div class="text-xl sm:text-2xl font-black text-[#0c2d4e]">83</div>
                <div class="text-xs text-emerald-600 mt-1">+4 this month</div>
              </div>
              <div class="bg-white rounded-xl p-3 sm:p-4 border border-slate-200">
                <div class="text-xs text-slate-400 mb-1">Revenue</div>
                <div class="text-xl sm:text-2xl font-black text-[#0c2d4e]">$11.6k</div>
                <div class="text-xs text-emerald-600 mt-1">+$420 vs last mo</div>
              </div>
              <div class="bg-white rounded-xl p-3 sm:p-4 border border-slate-200">
                <div class="text-xs text-slate-400 mb-1">Classes/week</div>
                <div class="text-xl sm:text-2xl font-black text-[#0c2d4e]">14</div>
                <div class="text-xs text-slate-400 mt-1">Avg 12 attendees</div>
              </div>
              <div class="bg-white rounded-xl p-3 sm:p-4 border border-slate-200">
                <div class="text-xs text-slate-400 mb-1">At-risk</div>
                <div class="text-xl sm:text-2xl font-black text-[#0c2d4e]">3</div>
                <div class="text-xs text-amber-600 mt-1">Needs attention</div>
              </div>
            </div>

            <!-- Two column lower section -->
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-2 sm:gap-3">
              <!-- Belt readiness -->
              <div class="bg-white rounded-xl p-3 sm:p-4 border border-slate-200">
                <div class="text-sm font-semibold text-[#0c2d4e] mb-3">Belt readiness</div>
                <div class="space-y-2">
                  <div class="flex items-center justify-between text-xs">
                    <span class="text-slate-600">Marcus Silva</span>
                    <span class="text-emerald-600 font-semibold">Ready to grade</span>
                  </div>
                  <div class="flex items-center justify-between text-xs">
                    <span class="text-slate-600">Tom Baker</span>
                    <span class="text-emerald-600 font-semibold">Ready to grade</span>
                  </div>
                  <div class="flex items-center justify-between text-xs">
                    <span class="text-slate-600">Sarah Chen</span>
                    <span class="text-slate-400">3 months to go</span>
                  </div>
                </div>
              </div>
              <!-- Upcoming classes -->
              <div class="bg-white rounded-xl p-3 sm:p-4 border border-slate-200">
                <div class="text-sm font-semibold text-[#0c2d4e] mb-3">Today's classes</div>
                <div class="space-y-2">
                  <div class="flex items-center justify-between text-xs">
                    <span class="text-slate-600">6am No-Gi</span>
                    <span class="text-slate-400">8 booked</span>
                  </div>
                  <div class="flex items-center justify-between text-xs">
                    <span class="text-slate-600">12pm Fundamentals</span>
                    <span class="text-slate-400">11 booked</span>
                  </div>
                  <div class="flex items-center justify-between text-xs">
                    <span class="text-slate-600">6pm All Levels</span>
                    <span class="text-slate-400">16 booked</span>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <p class="text-center text-sm text-slate-400 mt-6" data-animate="fade-in">
        Want to see the real thing? <a href={`mailto:${DEMO_EMAIL}?subject=GymDō Demo Request`} class="text-[#0891b2] hover:underline">Email us for a live walkthrough.</a>
      </p>
    </div>
  </section>

  <!-- Features -->
  <section class="section bg-white">
    <div class="container">
      <div class="max-w-2xl mx-auto text-center mb-16" data-animate="fade-up">
        <span class="badge badge-teal mb-4">What's included</span>
        <h2 class="text-4xl md:text-5xl font-black text-[#0c2d4e] mb-4">
          Everything your academy needs. Nothing it doesn't.
        </h2>
        <p class="text-slate-500 text-lg">Every feature exists because a BJJ gym owner needed it — not because a product manager thought it would look good on a pricing page.</p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6" data-animate="stagger">
        {features.map(feature => (
          <div class="card card-hover">
            <h3 class="text-[#0c2d4e] font-bold mb-2">{feature.title}</h3>
            <p class="text-slate-500 text-sm leading-relaxed">{feature.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Belt tracking spotlight -->
  <section class="section bg-[#0c2d4e]">
    <div class="container">
      <div class="grid lg:grid-cols-2 gap-16 items-center">
        <div data-animate="fade-up">
          <span class="badge mb-4" style="background:rgba(34,211,238,0.12);color:#67e8f9;border-color:rgba(34,211,238,0.2);">Belt tracking</span>
          <h2 class="text-4xl md:text-5xl font-black text-white mb-6">
            Never guess at a promotion again
          </h2>
          <p class="text-slate-300 text-lg leading-relaxed mb-6">
            A student asks if they're ready. You should have the answer immediately — not be reaching for a spreadsheet in front of your whole class. GymDō tracks every student's time at each belt automatically, measured against IBJJF minimums, updated every time they step on the mat.
          </p>
          <ul class="space-y-3 mb-8">
            {[
              'IBJJF-aligned minimum time tracking, automatic',
              'Stripe-by-stripe records from white to black',
              'Promotion history and coach notes logged forever',
              'Clear view of who\'s ready, who\'s close, who needs time',
            ].map(item => (
              <li class="flex items-start gap-3 text-slate-300">
                <span class="text-[#38bdf8] font-bold mt-0.5 flex-shrink-0">+</span>
                {item}
              </li>
            ))}
          </ul>
          <a href="/gymdo-website/features/belt-tracking" class="btn btn-primary btn-md">
            See belt tracking
          </a>
        </div>

        <div data-animate="scale-in">
          <div class="rounded-2xl border border-white/10 bg-white/[0.05] p-6 space-y-3">
            <div class="flex items-center justify-between mb-4">
              <h4 class="text-white font-semibold text-sm">Belt readiness</h4>
              <span class="badge" style="background:rgba(5,150,105,0.15);color:#6ee7b7;border-color:rgba(5,150,105,0.2);font-size:10px;">Live</span>
            </div>
            <div class="flex items-center justify-between p-3 rounded-lg bg-white/[0.06]">
              <div>
                <div class="text-white text-sm font-medium">Thiago Costa</div>
                <div class="text-slate-400 text-xs">Blue belt, 3 stripes</div>
              </div>
              <div class="text-right">
                <div class="text-xs font-semibold text-emerald-400">28mo / 24mo min</div>
                <div class="text-xs text-emerald-400">Ready to grade</div>
              </div>
            </div>
            <div class="flex items-center justify-between p-3 rounded-lg bg-white/[0.06]">
              <div>
                <div class="text-white text-sm font-medium">Mark Johnson</div>
                <div class="text-slate-400 text-xs">Purple belt, 2 stripes</div>
              </div>
              <div class="text-right">
                <div class="text-xs font-semibold text-slate-400">14mo / 18mo min</div>
                <div class="text-xs text-slate-400">4 months to go</div>
              </div>
            </div>
            <div class="flex items-center justify-between p-3 rounded-lg bg-white/[0.06]">
              <div>
                <div class="text-white text-sm font-medium">Sarah Chen</div>
                <div class="text-slate-400 text-xs">Blue belt, 4 stripes</div>
              </div>
              <div class="text-right">
                <div class="text-xs font-semibold text-emerald-400">26mo / 24mo min</div>
                <div class="text-xs text-emerald-400">Ready to grade</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Retention spotlight -->
  <section class="section bg-slate-50">
    <div class="container">
      <div class="grid lg:grid-cols-2 gap-16 items-center">
        <div data-animate="scale-in">
          <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm space-y-3">
            <div class="flex items-center justify-between mb-4">
              <h4 class="text-[#0c2d4e] font-semibold text-sm">Member health</h4>
              <span class="text-xs text-slate-400">Updated daily</span>
            </div>
            <div class="flex items-center justify-between p-3 rounded-lg bg-amber-50 border border-amber-100">
              <div>
                <div class="text-slate-800 text-sm font-medium">James O'Brien</div>
                <div class="text-slate-400 text-xs">Last class 18 days ago</div>
              </div>
              <div class="text-right">
                <div class="text-sm font-bold text-amber-600">Reach out</div>
                <div class="text-xs text-amber-500">High risk</div>
              </div>
            </div>
            <div class="flex items-center justify-between p-3 rounded-lg bg-slate-50 border border-slate-100">
              <div>
                <div class="text-slate-800 text-sm font-medium">Maria Santos</div>
                <div class="text-slate-400 text-xs">Last class 9 days ago</div>
              </div>
              <div class="text-right">
                <div class="text-sm font-bold text-slate-500">Watch</div>
                <div class="text-xs text-slate-400">Medium risk</div>
              </div>
            </div>
            <div class="flex items-center justify-between p-3 rounded-lg bg-emerald-50 border border-emerald-100">
              <div>
                <div class="text-slate-800 text-sm font-medium">Ben Taylor</div>
                <div class="text-slate-400 text-xs">Last class 3 days ago</div>
              </div>
              <div class="text-right">
                <div class="text-sm font-bold text-emerald-600">Thriving</div>
                <div class="text-xs text-emerald-500">Healthy</div>
              </div>
            </div>
            <div class="mt-2 pt-3 border-t border-slate-100">
              <p class="text-xs text-slate-400">1 member needs a check-in this week</p>
            </div>
          </div>
        </div>

        <div data-animate="fade-up">
          <span class="badge badge-teal mb-4">Member retention</span>
          <h2 class="text-4xl md:text-5xl font-black text-[#0c2d4e] mb-6">
            Know who's about to leave — two weeks before they do
          </h2>
          <p class="text-slate-500 text-lg leading-relaxed mb-6">
            The average BJJ gym loses members quietly. They stop enjoying it. They get busy. They drift. Then one day they cancel — and you had no idea it was coming. GymDō tracks every member's attendance pattern daily and flags anyone going quiet, while there's still time to reach out.
          </p>
          <ul class="space-y-3 mb-8">
            {[
              'Daily risk score for every active member',
              'Weekly digest: who needs a check-in this week',
              'Attendance heatmaps — 12 months of history per member',
              'One message at the right moment beats any marketing campaign',
            ].map(item => (
              <li class="flex items-start gap-3 text-slate-600">
                <span class="text-[#0891b2] font-bold mt-0.5 flex-shrink-0">+</span>
                {item}
              </li>
            ))}
          </ul>
          <a href="/gymdo-website/features/retention" class="btn btn-primary btn-md">
            See retention tools
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Comparison -->
  <section class="section bg-white">
    <div class="container">
      <div class="max-w-2xl mx-auto text-center mb-12" data-animate="fade-up">
        <span class="badge badge-navy mb-4">Why GymDō</span>
        <h2 class="text-4xl md:text-5xl font-black text-[#0c2d4e] mb-4">
          The only one built for BJJ
        </h2>
        <p class="text-slate-500 text-lg">Every competitor started somewhere else. Yoga, CrossFit, personal training. We started on the mat.</p>
      </div>

      <div class="overflow-x-auto" data-animate="fade-up">
        <table class="w-full max-w-3xl mx-auto text-sm">
          <thead>
            <tr class="border-b border-slate-200">
              <th class="text-left py-4 px-4 text-slate-400 font-normal">Platform</th>
              <th class="text-center py-4 px-4 text-slate-400 font-normal">No platform %</th>
              <th class="text-center py-4 px-4 text-slate-400 font-normal">Flat pricing</th>

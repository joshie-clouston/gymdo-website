---
export const prerender = true;
import BaseLayout from '../layouts/BaseLayout.astro';

const TRIAL_URL = 'https://gymdo-staff-app-main-yzbyzu.laravel.cloud/register';
const DEMO_EMAIL = 'josh@cmdsoftware.com.au';
---
<BaseLayout
  title="Contact - GymDo"
  description="Get in touch with GymDo. Questions, demo requests, or anything about the pilot program."
>
  <section class="section bg-[#0c2d4e] relative overflow-hidden">
    <div class="container relative" data-animate="fade-up">
      <div class="max-w-2xl mx-auto text-center">
        <span class="badge mb-4" style="background:rgba(34,211,238,0.12);color:#67e8f9;border-color:rgba(34,211,238,0.2);">Contact</span>
        <h1 class="text-5xl font-black text-white mb-6">Get in touch</h1>
        <p class="text-slate-300 text-xl mb-12">Want a demo, have a question, or just want to chat about whether GymDo is right for your academy? Email directly.</p>

        <div class="card max-w-md mx-auto text-left">
          <h2 class="text-[#0c2d4e] font-bold mb-4">Josh Clouston, Founder</h2>
          <div class="space-y-3">
            <a href={`mailto:${DEMO_EMAIL}`} class="flex items-center gap-3 text-slate-600 hover:text-[#0891b2] transition-colors">
              <span class="text-[#0891b2]">@</span>
              {DEMO_EMAIL}
            </a>
          </div>
          <div class="mt-6 pt-6 border-t border-slate-100">
            <p class="text-slate-400 text-sm">Based in Gold Coast, Australia. Usually reply same day.</p>
          </div>
        </div>

        <div class="mt-8">
          <a href={TRIAL_URL} class="btn btn-primary btn-lg">Start free trial instead</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

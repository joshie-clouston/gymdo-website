---
export const prerender = true;
import BaseLayout from '../layouts/BaseLayout.astro';

const TRIAL_URL = 'https://gymdo-staff-app-main-yzbyzu.laravel.cloud/register';
---
<BaseLayout
  title="Contact - GymDo"
  description="Get in touch with GymDo. Questions about the platform, pricing, or the pilot program."
>
  <section class="section bg-black relative overflow-hidden">
    <div class="absolute inset-0 bg-[linear-gradient(to_right,#27272a33_1px,transparent_1px),linear-gradient(to_bottom,#27272a33_1px,transparent_1px)] bg-[size:64px_64px]" aria-hidden="true"></div>
    <div class="container relative" data-animate="fade-up">
      <div class="max-w-2xl mx-auto text-center">
        <span class="badge badge-red mb-4">Contact</span>
        <h1 class="text-5xl font-black text-white mb-6">Get in touch</h1>
        <p class="text-zinc-400 text-xl mb-12">Questions, feature requests, or just want to chat about the pilot? Email directly.</p>

        <div class="card max-w-md mx-auto text-left">
          <h2 class="text-white font-bold mb-4">Josh Clouston, Founder</h2>
          <div class="space-y-3">
            <a href="mailto:josh@cmdsoftware.com.au" class="flex items-center gap-3 text-zinc-300 hover:text-white transition-colors">
              <span class="text-red-500">@</span>
              josh@cmdsoftware.com.au
            </a>
          </div>
          <div class="mt-6 pt-6 border-t border-white/5">
            <p class="text-zinc-500 text-sm">Based in Gold Coast, Australia. Usually reply same day.</p>
          </div>
        </div>

        <div class="mt-8">
          <a href={TRIAL_URL} class="btn btn-primary btn-lg">Start free trial instead</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

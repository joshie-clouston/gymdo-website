---
export const prerender = true;
import BaseLayout from '../layouts/BaseLayout.astro';

const TRIAL_URL = 'https://gymdo-staff-app-main-yzbyzu.laravel.cloud/register';
const DEMO_EMAIL = 'josh@cmdsoftware.com.au';

const featureGroups = [
  {
    title: 'Belt progression tracking',
    description: 'The only platform with real IBJJF-aligned belt tracking built in.',
    features: [
      'Time-in-belt tracking against IBJJF minimums, automatically',
      'Stripe-by-stripe records from white through black',
      'Promotion eligibility dashboard at a glance',
      'Full promotion history and coach notes',
      'Belt distribution view across your academy',
    ],
    href: '/gymdo-website/features/belt-tracking',
  },
  {
    title: 'Member retention scoring',
    description: 'Know who is going quiet before they cancel.',
    features: [
      'Daily risk scores for every active member',
      'Flags who needs a check-in this week',
      'Attendance heatmaps per member (12 months)',
      'Retention trends across your whole academy',
      'Intervene before it becomes a cancellation',
    ],
    href: '/gymdo-website/features/retention',
  },
  {
    title: 'Class scheduling and booking',
    description: 'Run your timetable with less admin overhead.',
    features: [
      'Visual weekly timetable with simple scheduling',
      'Members book from the app, no phone calls',
      'Real-time attendance and check-in tracking',
      'Class capacity limits',
      'Session history and attendance reports',
    ],
    href: null,
  },
  {
    title: 'Membership and billing',
    description: 'Your revenue, running on autopilot.',
    features: [
      'Stripe-powered recurring billing with automatic retries',
      'Membership pause and cancellation workflows',
      'Monthly Recurring Revenue dashboard',
      'Failed payment handling',
      'Payment history and receipts for members',
    ],
    href: null,
  },
  {
    title: 'Member mobile app',
    description: 'A clean, professional app experience for your members.',
    features: [
      'iOS and Android native app',
      'Class booking and cancellation',
      'Own belt and promotion history',
      'Membership status and billing management',
      'Check-in confirmation',
    ],
    href: null,
  },
  {
    title: 'Analytics and reporting',
    description: 'Everything you need to make good decisions about your gym.',
    features: [
      'Real-time MRR dashboard',
      'Attendance trends by class, day, and coach',
      'Belt distribution across your academy',
      'Member growth and churn tracking',
      'Retention trends over time',
    ],
    href: null,
  },
];
---
<BaseLayout
  title="Features - GymDo"
  description="GymDo features for BJJ gym management. Belt tracking, retention scoring, scheduling, billing, and a member mobile app built specifically for BJJ academies."
>
  <section class="section bg-[#0c2d4e] relative overflow-hidden">
    <div class="container relative text-center" data-animate="fade-up">
      <span class="badge mb-4" style="background:rgba(34,211,238,0.12);color:#67e8f9;border-color:rgba(34,211,238,0.2);">Features</span>
      <h1 class="text-5xl md:text-6xl font-black text-white mb-6">Built for BJJ.<br />Not retrofitted for it.</h1>
      <p class="text-slate-300 text-xl max-w-2xl mx-auto">Every feature was designed around how BJJ academies actually operate.</p>
    </div>
  </section>

  <section class="section bg-white">
    <div class="container">
      <div class="space-y-20">
        {featureGroups.map((group, i) => (
          <div class={`grid lg:grid-cols-2 gap-12 items-start ${i % 2 === 1 ? 'lg:grid-flow-dense' : ''}`} data-animate="fade-up">
            <div class={i % 2 === 1 ? 'lg:col-start-2' : ''}>
              <h2 class="text-3xl font-black text-[#0c2d4e] mb-3">{group.title}</h2>
              <p class="text-slate-500 text-lg mb-6">{group.description}</p>
              {group.href && (
                <a href={group.href} class="btn btn-primary btn-sm">Learn more</a>
              )}
            </div>
            <div class={`space-y-3 ${i % 2 === 1 ? 'lg:col-start-1' : ''}`}>
              {group.features.map(feature => (
                <div class="flex items-start gap-3 p-4 rounded-lg border border-slate-200 bg-slate-50">
                  <span class="text-[#0891b2] font-bold flex-shrink-0 mt-0.5">+</span>
                  <span class="text-slate-600 text-sm">{feature}</span>
                </div>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section bg-[#0c2d4e]">
    <div class="container text-center" data-animate="fade-up">
      <h2 class="text-4xl font-black text-white mb-4">Try every feature free for 30 days</h2>
      <p class="text-slate-300 mb-8">Or book a walkthrough and we'll show you the platform live.</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href={TRIAL_URL} class="btn btn-primary btn-lg">Start free trial</a>
        <a href={`mailto:${DEMO_EMAIL}?subject=GymDo Demo Request`} class="btn btn-outline-white btn-lg">Book a walkthrough</a>
      </div>
    </div>
  </section>
</BaseLayout>

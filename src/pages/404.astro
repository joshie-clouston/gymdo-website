---
export const prerender = true;
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="404 - GymDo" description="Page not found." noIndex={true}>
  <section class="section bg-black min-h-[60vh] flex items-center">
    <div class="container text-center">
      <div class="text-8xl font-black text-red-500 mb-4">404</div>
      <h1 class="text-4xl font-black text-white mb-4">Page not found</h1>
      <p class="text-zinc-400 mb-8">That page doesn't exist. Tap out and try again.</p>
      <a href="/" class="btn btn-primary btn-md">Back to home</a>
    </div>
  </section>
</BaseLayout>
